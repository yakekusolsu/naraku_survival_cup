{
  "name": "nsc-summer-2026-official",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently -k -n client,server -c cyan,orange \"vite --host 0.0.0.0\" \"tsx watch server/index.ts\"",
    "dev:client": "vite --host 0.0.0.0",
    "dev:server": "tsx watch server/index.ts",
    "build": "vue-tsc --noEmit && vite build && tsc -p tsconfig.server.json",
    "start": "node dist-server/server/index.js",
    "preview": "vite preview --host 0.0.0.0",
    "lint": "eslint . --ext .ts,.vue --max-warnings=0",
    "format": "prettier --write ."
  },
  "dependencies": {
    "@lucide/vue": "^1.25.0",
    "@vitejs/plugin-vue": "^6.0.1",
    "autoprefixer": "^10.4.21",
    "cors": "^2.8.5",
    "express": "^5.2.1",
    "gsap": "^3.14.2",
    "lenis": "^1.3.15",
    "pinia": "^3.0.4",
    "postcss": "^8.5.6",
    "socket.io": "^4.8.1",
    "socket.io-client": "^4.8.1",
    "swagger-ui-express": "^5.0.1",
    "tailwindcss": "^3.4.19",
    "three": "^0.182.0",
    "vue": "^3.5.25",
    "vue-router": "^4.6.4"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "^25.0.3",
    "@types/swagger-ui-express": "^4.1.8",
    "@types/three": "^0.185.1",
    "@typescript-eslint/eslint-plugin": "^8.50.0",
    "@typescript-eslint/parser": "^8.50.0",
    "@vue/eslint-config-typescript": "^14.6.0",
    "concurrently": "^9.2.1",
    "eslint": "^9.39.2",
    "eslint-plugin-vue": "^10.6.2",
    "prettier": "^3.7.4",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vite": "^7.3.0",
    "vue-tsc": "^3.1.8"
  }
}
